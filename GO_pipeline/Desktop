    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "from sklearn.model_selection import GroupShuffleSplit, StratifiedGroupKFold\n",
    "from sklearn.preprocessing import StandardScaler, label_binarize\n",
    "from sklearn.decomposition import PCA\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.pipeline import Pipeline\n",
    "\n",
    "from sklearn.metrics import (\n",
    "    accuracy_score,\n",
    "    balanced_accuracy_score,\n",
    "    f1_score,\n",
    "    roc_auc_score,\n",
    "    precision_score,\n",
    "    recall_score\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# Prepare features / labels\n",
    "# =========================\n",
    "feature_cols = expr_with_meta.columns.difference(\n",
    "    ['hemisphere', 'donor_id', 'transcriptomics_batch', 'cell_type']\n",
    ")\n",
    "\n",
    "X = expr_with_meta[feature_cols].values\n",
    "y = expr_with_meta['cell_type'].values\n",
    "groups = expr_with_meta['donor_id'].values\n",
    "\n",
    "all_classes = np.unique(y)\n",
    "\n",
    "# =========================================================\n",
    "# 1. TRAIN / TEST SPLIT (STRICT BY DONOR → NO LEAKAGE)\n",
    "# =========================================================\n",
    "gss = GroupShuffleSplit(n_splits=1, test_size=0.3, random_state=42)\n",
    "\n",
    "train_idx, test_idx = next(gss.split(X, y, groups=groups))\n",
    "\n",
    "X_train, X_test = X[train_idx], X[test_idx]\n",
    "y_train, y_test = y[train_idx], y[test_idx]\n",
    "groups_train = groups[train_idx]\n",
    "\n",
    "# =========================================================\n",
    "# 2. CROSS-VALIDATION (within training donors only)\n",
    "# =========================================================\n",
    "cv = StratifiedGroupKFold(n_splits=3, shuffle=True, random_state=42)\n",
    "\n",
    "val_acc_list = []\n",
    "val_bal_acc_list = []\n",
    "val_f1_list = []\n",
    "val_auc_list = []\n",
    "\n",
    "test_probas = []\n",
    "\n",
    "# =========================================================\n",
    "# CV LOOP\n",
    "# =========================================================\n",
    "for fold, (tr_idx, val_idx) in enumerate(cv.split(X_train, y_train, groups_train)):\n",
    "\n",
    "    print(f\"========== Fold {fold+1} ==========\")\n",
    "\n",
    "    X_tr, X_val = X_train[tr_idx], X_train[val_idx]\n",
    "    y_tr, y_val = y_train[tr_idx], y_train[val_idx]\n",
    "\n",
    "    # =========================\n",
    "    # PCA + Logistic Regression\n",
    "    # =========================\n",
    "    pipe = Pipeline([\n",
    "        ('scaler', StandardScaler()),\n",
    "        ('pca', PCA(n_components=50, random_state=42)),\n",
    "        ('clf', LogisticRegression(\n",
    "            max_iter=1000,\n",
    "            solver='lbfgs',\n",
    "            random_state=42\n",
    "        ))\n",
    "    ])\n",
    "\n",
    "    pipe.fit(X_tr, y_tr)\n",
    "\n",
    "    # =========================\n",
    "    # VALIDATION\n",
    "    # =========================\n",
    "    y_val_pred = pipe.predict(X_val)\n",
    "    y_val_proba = pipe.predict_proba(X_val)\n",
    "\n",
    "    val_acc_list.append(accuracy_score(y_val, y_val_pred))\n",
    "    val_bal_acc_list.append(balanced_accuracy_score(y_val, y_val_pred))\n",
    "    val_f1_list.append(f1_score(y_val, y_val_pred, average='macro'))\n",
    "\n",
    "    y_val_bin = label_binarize(y_val, classes=all_classes)\n",
    "    val_auc_list.append(\n",
    "        roc_auc_score(y_val_bin, y_val_proba, average='macro', multi_class='ovr')\n",
    "    )\n",
    "\n",
    "    # =========================\n",
    "    # TEST ENSEMBLE (store probabilities only)\n",
    "    # =========================\n",
    "    test_probas.append(pipe.predict_proba(X_test))\n",
    "\n",
    "# =========================================================\n",
    "# 3. CV SUMMARY\n",
    "# =========================================================\n",
    "print(\"\\n===== CV Results =====\")\n",
    "print(f\"Mean accuracy        : {np.mean(val_acc_list):.4f}\")\n",
    "print(f\"Mean balanced acc    : {np.mean(val_bal_acc_list):.4f}\")\n",
    "print(f\"Mean macro F1        : {np.mean(val_f1_list):.4f}\")\n",
    "print(f\"Mean macro AUC       : {np.mean(val_auc_list):.4f}\")\n",
    "\n",
    "# =========================================================\n",
    "# 4. TEST ENSEMBLE (average predictions)\n",
    "# =========================================================\n",
    "avg_test_proba = np.mean(test_probas, axis=0)\n",
    "\n",
    "class_labels = all_classes\n",
    "y_test_pred = class_labels[np.argmax(avg_test_proba, axis=1)]\n",
    "\n",
    "# =========================================================\n",
    "# 5. TEST METRICS\n",
    "# =========================================================\n",
    "test_acc = accuracy_score(y_test, y_test_pred)\n",
    "test_bal_acc = balanced_accuracy_score(y_test, y_test_pred)\n",
    "test_f1 = f1_score(y_test, y_test_pred, average='macro')\n",
    "\n",
    "y_test_bin = label_binarize(y_test, classes=all_classes)\n",
    "test_auc = roc_auc_score(\n",
    "    y_test_bin,\n",
    "    avg_test_proba,\n",
    "    average='macro',\n",
    "    multi_class='ovr'\n",
    ")\n",
    "\n",
    "print(\"\\n===== Test Results (CV Ensemble) =====\")\n",
    "print(f\"Accuracy         : {test_acc:.4f}\")\n",
    "print(f\"Balanced Acc     : {test_bal_acc:.4f}\")\n",
    "print(f\"Macro F1         : {test_f1:.4f}\")\n",
    "print(f\"Macro AUC        : {test_auc:.4f}\")\n",
    "\n",
    "# =========================================================\n",
    "# 6. PER-CLASS METRICS\n",
    "# =========================================================\n",
    "per_class_precision = precision_score(\n",
    "    y_test, y_test_pred, average=None, labels=class_labels\n",
    ")\n",
    "\n",
    "per_class_recall = recall_score(\n",
    "    y_test, y_test_pred, average=None, labels=class_labels\n",
    ")\n",
    "\n",
    "pr_table = pd.DataFrame({\n",
    "    \"Precision\": per_class_precision,\n",
    "    \"Recall\": per_class_recall\n",
    "}, index=class_labels)\n",
    "\n",
    "print(\"\\n===== Per-class Precision / Recall =====\")\n",
    "display(pr_table)"
